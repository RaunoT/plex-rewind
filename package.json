    "motion": "^12.28.2",
    "next": "^16.1.4",
    "next-auth": "^4.24.13",
    "next-intl": "^4.7.0",
    "next-runtime-env": "^3.3.0",
    "qs": "^6.14.1",
    "react": "19.2.3",
    "react-aria-components": "^1.14.0",
    "react-dom": "19.2.3",
    "react-sortablejs": "^6.1.4",
    "sharp": "^0.34.5",
    "sortablejs": "^1.15.6",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.5"
