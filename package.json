{
  "name": "plex-rewind",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "next build",
    "lint": "eslint .",
    "lint:types": "tsc --noEmit",
    "lint:css": "stylelint --cache \"**/*.css\"",
