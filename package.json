    "@serwist/next": "^9.5.0",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.0.10",
    "@types/qs": "^6.14.0",
    "@types/react": "19.2.9",
